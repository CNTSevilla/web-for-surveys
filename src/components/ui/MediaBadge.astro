---
/**
 * MediaBadge.astro - Badge para enlaces a artículos o videos de medios.
 *
 * Muestra un enlace con un icono (documento para artículos, play para videos)
 * y una etiqueta. Al hacer hover invierte los colores.
 * Se usa para referenciar coberturas mediáticas de la victoria de Palmete.
 *
 * @prop {string} href - URL del enlace (se abre en nueva pestaña)
 * @prop {'article'|'video'} [type='article'] - Tipo de medio para el icono
 * @prop {string} label - Texto visible del badge (nombre del medio)
 * @prop {'default'|'light'} [variant='default'] - Variante para fondos oscuros
 */

interface Props {
  /** URL del enlace (se abre en nueva pestaña con noopener) */
  href: string;
  /** Tipo de medio: 'article' (icono documento) o 'video' (icono play) */
  type?: 'article' | 'video';
  /** Texto visible del badge (nombre del medio o descripción) */
  label: string;
  /** Variante: 'default' o 'light' (para fondos oscuros) */
  variant?: 'default' | 'light';
}

const { href, type = 'article', label, variant = 'default' } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class:list={['media-badge', type, { 'article--light': variant === 'light' }]}
>
  {type === 'article' ? (
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M19 20H5C3.89543 20 3 19.1046 3 18V6C3 4.89543 3.89543 4 5 4H19C20.1046 4 21 4.89543 21 6V18C21 19.1046 20.1046 20 19 20Z"
        stroke="currentColor"
        stroke-width="2"
      ></path>
      <path
        d="M7 8H17M7 12H17M7 16H13"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      ></path>
    </svg>
  ) : (
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M8 5V19L19 12L8 5Z"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      ></path>
    </svg>
  )}
  <span>{label}</span>
</a>
