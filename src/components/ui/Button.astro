---
/**
 * Button.astro - Componente reutilizable de botón/enlace.
 *
 * Renderiza automáticamente un <a> si se proporciona href,
 * o un <button> si no. Útil para CTAs y acciones.
 *
 * @prop {string} [href='#'] - Si se proporciona, renderiza un enlace <a>
 * @prop {'primary'|'secondary'} [variant='primary'] - Variante de estilo:
 *   - 'primary': fondo verde con texto blanco
 *   - 'secondary': borde oscuro con fondo transparente
 * @prop {string} [class] - Clases CSS adicionales para personalización
 */

interface Props {
  /** Si se proporciona, renderiza un <a> en lugar de <button> */
  href?: string;
  /** Variante de estilo: 'primary' (verde) o 'secondary' (borde oscuro) */
  variant?: 'primary' | 'secondary';
  /** Clases CSS adicionales para personalización */
  class?: string;
}

const { href = '#', variant = 'primary', class: className = '' } = Astro.props;
---

{href ? (
  <a href={href} class:list={['button', variant, className]}>
    <slot />
  </a>
) : (
  <button class:list={['button', variant, className]}>
    <slot />
  </button>
)}

<style>
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.875rem 1.75rem;
    border-radius: 8px;
    transition:
      transform 140ms ease,
      box-shadow 140ms ease;
    cursor: pointer;
    border: none;
  }

  .button.primary {
    background: var(--color-accent);
    color: #fff;
  }

  .button.primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(46, 204, 113, 0.35);
  }

  .button.secondary {
    background: transparent;
    color: #111;
    border: 2px solid #111;
  }

  .button.secondary:hover {
    background: #111;
    color: white;
  }
</style>