---
/**
 * Badge.astro - Componente reutilizable de etiqueta/insignia.
 *
 * Muestra un pequeño contenedor con borde, icono opcional y texto.
 * Se utiliza para destacar información breve como estadísticas o estados.
 *
 * @prop {string} [icon] - Icono SVG opcional para mostrar a la izquierda del texto
 * @prop {'default'|'success'} [variant='default'] - Variante de estilo:
 *   - 'default': borde gris oscuro, texto negro
 *   - 'success': borde verde, texto verde
 * @prop {string} [class] - Clases CSS adicionales para personalización
 */

interface Props {
  /** Icono SVG opcional para mostrar a la izquierda del texto */
  icon?: string;
  /** Variante de estilo: 'default' (oscuro) o 'success' (verde) */
  variant?: 'default' | 'success';
  /** Clases CSS adicionales para personalización */
  class?: string;
}

const { icon, variant = 'default', class: className = '' } = Astro.props;
---

<div class:list={['badge', variant, className]}>
  {icon && <span class="badge-icon">{icon}</span>}
  <span class="badge-text">
    <slot />
  </span>
</div>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    padding: 0.4rem 0.75rem;
    border-radius: 4px;
  }

  .badge.default {
    color: #000;
    border: 1px solid rgba(0, 0, 0, 0.3);
  }

  .badge.success {
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
  }

  .badge-icon {
    display: flex;
    align-items: center;
  }

  .badge-icon :global(svg) {
    width: 16px;
    height: 16px;
    color: var(--color-accent);
  }

  .badge-text {
    line-height: 1;
  }
</style>