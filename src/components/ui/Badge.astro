---
interface Props {
  icon?: string;
  variant?: 'default' | 'success';
  class?: string;
}

const { icon, variant = 'default', class: className = '' } = Astro.props;
---

<div class:list={['badge', variant, className]}>
  {icon && <span class="badge-icon">{icon}</span>}
  <span class="badge-text">
    <slot />
  </span>
</div>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    padding: 0.4rem 0.75rem;
    border-radius: 4px;
  }

  .badge.default {
    color: #000;
    border: 1px solid rgba(0, 0, 0, 0.3);
  }

  .badge.success {
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
  }

  .badge-icon {
    display: flex;
    align-items: center;
  }

  .badge-icon :global(svg) {
    width: 16px;
    height: 16px;
    color: var(--color-accent);
  }

  .badge-text {
    line-height: 1;
  }
</style>