  </div>
</section>

<style>
  .story-section {
    width: 100%;
    background: #fff;
    padding: 7rem 3.75rem;
    padding-top: 10rem;
    overflow: hidden;
  }

  .story-container {
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr;
    align-items: center;
    justify-content: center;
    justify-items: center;
    gap: 2rem;
  }

  .story-text {
    width: 100%;
  }

  .story-text h2 {
    font-size: clamp(2.8rem, 4vw, 4.6rem);
    line-height: 1.2;
    font-weight: 900;
    margin: 0 0 1.4rem;
    color: #111;
    letter-spacing: -0.04em;
  }

  .story-text h2 span {
    color: var(--color-accent);
  }

  .story-text p {
    font-size: 1.3rem;
    line-height: 1.65;
    color: #222;
    max-width: 360px;
    margin-bottom: 2rem;
  }

  .story-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    border: 2px solid #111;
    padding: 1rem 1.4rem;
    text-decoration: none;
    color: #111;
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    transition: 0.2s ease;
  }

  .story-btn:hover {
    background: #111;
    color: white;
  }

  .cta-button {
    margin-bottom: 2rem;
  }

  .articles-label {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    color: #555;
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .article-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .article-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    color: #111;
    padding: 0.4rem 0.75rem;
    border: 1px solid rgba(0, 0, 0, 0.3);
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .article-badge:hover {
    background: #111;
    color: white;
    border-color: #111;
  }

  .article-badge svg {
    flex-shrink: 0;
  }

  .videos-label {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    color: #555;
    margin-bottom: 0.75rem;
    letter-spacing: 0.02em;
    margin-top: 1.5rem;
  }

  .video-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .video-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    color: #111;
    padding: 0.4rem 0.75rem;
    border: 1px solid rgba(0, 0, 0, 0.3);
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .video-badge:hover {
    background: #ff0000;
    color: #fff;
    border-color: #ff0000;
  }

  .video-badge svg {
    flex-shrink: 0;
  }

  .story-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 500px;
  }

  .story-image {
    position: relative;
    width: 50vw;
    min-width: 580px;
    border-radius: 999px;
    object-fit: contain;
    z-index: 2;
  }

  @media (max-width: 1080px) {
    .story-image {
      min-width: 0;
      max-width: 100%;
      width: 100%;
    }

    .story-visual {
      min-height: 380px;
      overflow: hidden;
      min-width: 0;
    }

    .article-badge,
    .video-badge {
      white-space: nowrap;
    }

    .story-container {
      grid-template-columns: 1fr;
      text-align: center;
      min-width: 0;
      width: 100%;
      overflow: hidden;
    }

    .story-text {
      margin: 0;
      width: 100%;
      box-sizing: border-box;
    }

    .story-text p {
      max-width: none;
      margin-left: 0;
      margin-right: 0;
    }

    .article-badges,
    .video-badges {
      width: 100%;
      justify-content: center;
      box-sizing: border-box;
    }

    .story-btn {
      justify-content: center;
    }
  }

  @media (max-width: 640px) {
    .story-section {
      padding: 4rem 1.25rem;
      padding-top: 14rem;
    }

    .story-text h2 {
      font-size: 2.2rem;
    }

    .story-btn {
      width: 100%;
      justify-content: center;
    }

    .story-visual {
      min-height: auto;
    }
  }

  @media (max-width: 500px) {
    .story-text h2 {
      font-size: 2rem;
    }

    .story-text {
      max-width: 100%;
    }

    .story-text p {
      max-width: 100%;
      font-size: 1.1rem;
    }

    .article-badges,
    .video-badges {
      max-width: 100%;
    }

    .cta-button {
      margin-bottom: 0;
    }
  }
</style>
