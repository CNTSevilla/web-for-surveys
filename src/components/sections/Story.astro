---
/**
 * Story.astro - Sección narrativa sobre la victoria de Palmete.
 *
 * Cuenta la historia de las 11 familias que frenaron un desahucio ilegal
 * y consiguieron alquileres simbólicos de 200€ en viviendas VPO.
 *
 * Incluye:
 * - Descripción del logro con énfasis en la organización colectiva
 * - Enlaces a artículos de prensa (El Diario, La Voz del Sur, 101TV)
 * - Enlaces a 4 videos de YouTube documentando el proceso
 * - Imagen de la protesta/celebración
 * - CTA hacia la página "La Solución"
 */

import MediaBadge from '../ui/MediaBadge.astro';
---

<section class="story-section">
  <div class="story-container">
    <div class="story-text">
      <h2>
        Lo conseguimos<br />
        en <span>Palmete, Sevilla.</span>
      </h2>

      <p>
        <strong
          >11 familias unidas y asesoradas por las organizaciones</strong
        >, han frenado un intento de desahucio ilegal y <strong>han conseguido
        alquileres</strong> simbólicos <strong>de 200€</strong> en viviendas VPO.
      </p>

      <p class="media-label">Así lo contaron los medios:</p>

      <div class="media-badges-group">
        <MediaBadge href="https://www.eldiario.es/sevilla/chupan-sangre-protesta-arropa-sevilla-11-familias-expulsadas-vpo-comprarlas-banco_1_12988074.html" type="article" label="El Diario de Sevilla" />
        <MediaBadge href="https://www.lavozdelsur.es/ediciones/sevilla/indignacion-desahucio-en-sevilla-11-familias-con-menores-cargo-en-bloque-propiedad-santander_349389_102.html" type="article" label="La Voz del Sur" />
        <MediaBadge href="https://www.101tv.es/la-solidaridad-obrera-frena-la-entrada-de-los-especuladores-en-palmete-el-banco-se-va-las-familias-se-quedan/" type="article" label="101TV" />
      </div>

      <p class="media-label">Mira el proceso en video:</p>

      <div class="media-badges-group">
        <MediaBadge href="https://www.youtube.com/watch?v=wmGADykbbBc" type="video" label="Situación previa" />
        <MediaBadge href="https://www.youtube.com/watch?v=BbBBH6ixPFg" type="video" label="Quejas y organización" />
        <MediaBadge href="https://www.youtube.com/watch?v=iqAX6a_0PgI" type="video" label="La manifestación" />
        <MediaBadge href="https://www.youtube.com/shorts/Fxe_K3l3FDU" type="video" label="La victoria (Short)" />
      </div>

      <a href="/la-solucion" class="cta-button">
        DESCUBRE LA SOLUCIÓN
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M5 12H19M19 12L12 5M19 12L12 19"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>

    <div class="story-visual">
      <img
        src="/images/story-bg.png"
        alt="Personas levantando pancarta"
        class="story-image"
      />
    </div>
  </div>
</section>

<style>
  .story-section {
    width: 100%;
    background: #fff;
    padding: 7rem 3.75rem;
    padding-top: 10rem;
    overflow: hidden;
  }

  .story-container {
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr;
    align-items: center;
    justify-content: center;
    justify-items: center;
    gap: 2rem;
  }

  .story-text {
    width: 100%;
  }

  .story-text h2 {
    font-size: clamp(2.8rem, 4vw, 4.6rem);
    line-height: 1.2;
    font-weight: 900;
    margin: 0 0 1.4rem;
    color: #111;
    letter-spacing: -0.04em;
  }

  .story-text h2 span {
    color: var(--color-accent);
  }

  .story-text p {
    font-size: 1.3rem;
    line-height: 1.65;
    color: #222;
    max-width: 360px;
    margin-bottom: 2rem;
  }

  .cta-button {
    margin-bottom: 2rem;
  }

  .media-label {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    color: #555;
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .media-label + .media-badges-group {
    margin-bottom: 2rem;
  }

  .media-badges-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .story-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 500px;
  }

  .story-image {
    position: relative;
    width: 50vw;
    min-width: 580px;
    border-radius: 999px;
    object-fit: contain;
    z-index: 2;
  }

  @media (max-width: 1080px) {
    .story-image {
      min-width: 0;
      max-width: 100%;
      width: 100%;
    }

    .story-visual {
      min-height: 380px;
      overflow: hidden;
      min-width: 0;
    }

    .story-container {
      grid-template-columns: 1fr;
      text-align: center;
      min-width: 0;
      width: 100%;
      overflow: hidden;
      padding-top: 2rem;
    }

    .story-text {
      margin: 0;
      width: 100%;
      box-sizing: border-box;
    }

    .story-text p {
      max-width: none;
      margin-left: 0;
      margin-right: 0;
    }

    .media-badges-group {
      width: 100%;
      justify-content: center;
      box-sizing: border-box;
    }
  }

  @media (max-width: 640px) {
    .story-section {
      padding: 4rem 1.25rem;
      padding-top: 14rem;
    }

    .story-text h2 {
      font-size: 2.4rem;
    }

    .story-visual {
      min-height: auto;
    }
  }

  @media (max-width: 500px) {
    .story-text h2 {
      font-size: 2.2rem;
    }

    .story-text {
      max-width: 100%;
    }

    .story-text p {
      max-width: 100%;
      font-size: 1.1rem;
    }

    .media-badges-group {
      max-width: 100%;
    }

    .cta-button {
      margin-bottom: 0;
    }
  }
</style>
