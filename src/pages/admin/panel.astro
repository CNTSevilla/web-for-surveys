---
import Layout from "../../layouts/Layout.astro";
import '../../styles/admin.css';
---

<Layout title="Panel Admin - Familias Palmete" showFooter={false}>
  <main class="admin-panel">
    <div class="panel-container">
      <div class="panel-header">
        <div>
          <div class="panel-title">
            <div class="panel-icon-wrapper">
              <svg class="panel-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 9.5L12 4L21 9.5V20C21 20.5523 20.5523 21 20 21H4C3.44772 21 3 20.5523 3 20V9.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                <path d="M9 21V12H15V21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </div>
            <h1>Gestión de Alquileres</h1>
          </div>
          <p class="panel-subtitle">Administra los registros de alquileres</p>
        </div>
        <a href="/" class="back-button">← Volver a la web</a>
      </div>

      <div class="controls">
        <div class="search-wrapper">
          <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
          <input type="text" id="searchInput" placeholder="Buscar por barrio..." class="search-input" />
        </div>
      </div>

      <div id="loadingMsg" class="loading">Cargando datos...</div>
      <div id="errorMsg" class="error"></div>

      <div class="table-header">
        <span id="totalRecords" class="table-info"></span>
        <span id="pageRecords" class="table-info"></span>
      </div>

      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Barrio</th>
              <th>Alquiler</th>
              <th>Dirección</th>
              <th>Email</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody id="tableBody">
            <!-- Datos se cargan via JS -->
          </tbody>
        </table>
      </div>

      <div id="pagination" class="pagination"></div>
    </div>
  </main>

  <script>
    const tableBody = document.getElementById('tableBody') as HTMLElement;
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const loadingMsg = document.getElementById('loadingMsg') as HTMLElement;
    const errorMsg = document.getElementById('errorMsg') as HTMLElement;
    const pagination = document.getElementById('pagination') as HTMLElement;
    const totalRecords = document.getElementById('totalRecords') as HTMLElement;
    const pageRecords = document.getElementById('pageRecords') as HTMLElement;

    let currentPage = 1;
    const itemsPerPage = 40;
    let allData: any[] = [];
    let filteredData: any[] = [];
    let totalDbRecords = 0;

    // Verificar autenticación
    const token = localStorage.getItem('adminToken');
    if (!token) {
      window.location.href = '/admin';
    }

    const verifyToken = async () => {
      try {
        const response = await fetch('/api/verify-token', {
          method: 'POST',
          headers: { 
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}` 
          }
        });
        
        const data = await response.json();
        return data.valid;
      } catch {
        return false;
      }
    };

    // Verificar token al cargar
    (async () => {
      const isValid = await verifyToken();
      if (!isValid) {
        localStorage.removeItem('adminToken');
        window.location.href = '/admin';
      }
    })();

    // Verificar token cada 5 minutos
    setInterval(async () => {
      const isValid = await verifyToken();
      if (!isValid) {
        localStorage.removeItem('adminToken');
        window.location.href = '/admin';
      }
    }, 5 * 60 * 1000);

    const fetchData = async (page: number = 1) => {
      loadingMsg.style.display = 'block';
      errorMsg.style.display = 'none';
      errorMsg.textContent = '';
      try {
        const response = await fetch(`/api/alquileres?page=${page}&limit=${itemsPerPage}&search=${searchInput.value}`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });

        if (response.status === 401) {
          localStorage.removeItem('adminToken');
          window.location.href = '/admin';
          return;
        }

        const data = await response.json();
        totalDbRecords = data.total || 0;
        allData = data.items || [];
        filteredData = allData;
        renderTable();
        renderPagination(data.totalPages || 1, data.currentPage || 1);
        renderInfo(data.totalPages || 1, data.currentPage || 1);
      } catch (error) {
        errorMsg.textContent = 'Error al cargar datos';
        errorMsg.style.display = 'block';
      } finally {
        loadingMsg.style.display = 'none';
      }
    };

    const renderTable = () => {
      tableBody.innerHTML = '';
      if (filteredData.length === 0) {
        tableBody.innerHTML = '<tr><td colspan="6" class="no-data">No se encontraron registros</td></tr>';
        return;
      }

      filteredData.forEach(item => {
        const row = document.createElement('tr');
        row.innerHTML = `
          <td>${item.id || '-'}</td>
          <td>${item.barrio || '-'}</td>
          <td>${item.alquiler ? item.alquiler + '€' : '-'}</td>
          <td>${item.direccion || '-'}</td>
          <td>${item.quiere_contacto && item.email ? item.email : '-'}</td>
          <td>
            <button class="delete-btn" data-id="${item.id}">Borrar</button>
          </td>
        `;
        tableBody.appendChild(row);
      });

      // Añadir event listeners a botones de borrar
      document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const id = (e.target as HTMLElement).getAttribute('data-id');
          if (confirm('¿Estás seguro de borrar este registro?')) {
            await deleteItem(id);
          }
        });
      });
    };

    const renderPagination = (totalPages: number, current: number) => {
      pagination.innerHTML = '';
      for (let i = 1; i <= totalPages; i++) {
        const btn = document.createElement('button');
        btn.textContent = i.toString();
        btn.className = i === current ? 'active' : '';
        btn.addEventListener('click', () => {
          currentPage = i;
          fetchData(i);
        });
        pagination.appendChild(btn);
      }
    };

    const renderInfo = (totalPages: number, current: number) => {
      totalRecords.textContent = `Total: ${totalDbRecords} registros`;
      const filteredCount = filteredData.length;
      pageRecords.textContent = `Mostrando ${filteredCount} registros`;
    };

    const deleteItem = async (id: string) => {
      try {
        const response = await fetch(`/api/alquileres/${id}`, {
          method: 'DELETE',
          headers: { 'Authorization': `Bearer ${token}` }
        });

        if (response.ok) {
          showNotification('Registro borrado correctamente', 'success');
          fetchData(currentPage);
        } else {
          showNotification('Error al borrar registro', 'error');
        }
      } catch (error) {
        showNotification('Error de conexión', 'error');
      }
    };

    const showNotification = (message: string, type: 'success' | 'error') => {
      const notification = document.createElement('div');
      notification.className = `notification ${type}`;
      notification.textContent = message;
      document.body.appendChild(notification);
      setTimeout(() => notification.remove(), 3000);
    };

    // Event listeners
    searchInput.addEventListener('input', () => {
      const searchTerm = searchInput.value.toLowerCase();
      filteredData = allData.filter(item =>
        (item.barrio && item.barrio.toLowerCase().includes(searchTerm)) ||
        (item.email && item.email.toLowerCase().includes(searchTerm)) ||
        (item.alquiler && item.alquiler.toString().includes(searchTerm)) ||
        (item.direccion && item.direccion.toLowerCase().includes(searchTerm))
      );
      renderTable();
      renderInfo(1, 1);
    });

    // Cargar datos inicial
    fetchData();
  </script>
</Layout>
