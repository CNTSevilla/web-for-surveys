---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Admin - Familias Palmete" showFooter={false}>
  <main class="admin-login">
    <div class="login-container">
      <div class="login-header">
        <div class="logo">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 9.5L12 4L21 9.5V20C21 20.5523 20.5523 21 20 21H4C3.44772 21 3 20.5523 3 20V9.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
            <path d="M9 21V12H15V21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </div>
        <h1>Acceso</h1>
        <p>Ingresa tus credenciales para gestionar los alquileres</p>
      </div>

      <form id="loginForm" class="login-form">
        <div class="form-group">
          <label for="username">Usuario</label>
          <div class="input-wrapper">
            <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            <input type="text" id="username" name="username" placeholder="Introduce tu usuario" required />
          </div>
        </div>
        <div class="form-group">
          <label for="password">Contraseña</label>
          <div class="input-wrapper">
            <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            <input type="password" id="password" name="password" placeholder="••••••••" required />
          </div>
        </div>
        <button type="submit" class="login-button">Entrar</button>
        <p id="errorMsg" class="error-message"></p>
      </form>

      <a href="/" class="back-link">← Volver a la página principal</a>
    </div>
  </main>

  <script>
    const form = document.getElementById('loginForm') as HTMLFormElement;
    const errorMsg = document.getElementById('errorMsg') as HTMLElement;

    // Ocultar mensaje de error inicialmente
    errorMsg.style.display = 'none';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const username = formData.get('username');
      const password = formData.get('password');

      // Ocultar error anterior
      errorMsg.style.display = 'none';
      errorMsg.textContent = '';

      try {
        const response = await fetch('/api/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, password })
        });

        const data = await response.json();

        if (response.ok && data.success) {
          localStorage.setItem('adminToken', data.token);
          window.location.href = '/admin/panel';
        } else {
          errorMsg.textContent = data.error || 'Error de autenticación';
          errorMsg.style.display = 'block';
        }
      } catch (error) {
        errorMsg.textContent = 'Error de conexión';
        errorMsg.style.display = 'block';
      }
    });
  </script>
</Layout>

<style>
  .admin-login {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0a1929;
    padding: 2rem;
  }

  .login-container {
    background: rgba(255, 255, 255, 0.03);
    padding: 3rem;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    width: 100%;
    max-width: 420px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .login-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .login-header .logo {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    background: var(--color-accent);
    border-radius: 12px;
    color: #fff;
  }

  .login-header .logo svg {
    width: 44px;
    height: 44px;
  }

  .login-header h1 {
    font-family: var(--font-display);
    color: #fff;
    font-size: 1.8rem;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .login-header p {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9rem;
    margin: 0;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-family: var(--font-display);
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .input-wrapper {
    position: relative;
  }

  .input-wrapper input {
    width: 100%;
    padding: 0.9rem 1rem;
    padding-left: 2.8rem;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
    font-size: 1rem;
    transition: all 0.2s;
    box-sizing: border-box;
  }

  .input-wrapper input:focus {
    outline: none;
    border-color: var(--color-accent);
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 0 0 3px rgba(0, 194, 111, 0.2);
  }

  .input-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(255, 255, 255, 0.4);
    font-size: 1rem;
  }

  .login-button {
    background: var(--color-accent);
    color: #fff;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    padding: 0.9rem;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-top: 0.5rem;
  }

  .login-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(46, 204, 113, 0.4);
  }

  .login-button:active {
    transform: translateY(0);
  }

  .error-message {
    color: #ff6b6b;
    font-size: 0.85rem;
    text-align: center;
    margin: 0;
    padding: 0.5rem;
    background: rgba(255, 107, 107, 0.1);
    border-radius: 6px;
    display: none;
  }

  .back-link {
    display: block;
    text-align: center;
    margin-top: 1.5rem;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 500px) {
    .admin-login {
      padding: 0;
      align-items: stretch;
    }

    .login-container {
      max-width: 100%;
      border-radius: 0;
      border: none;
      padding: 2rem 1.5rem;
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .login-header {
      margin-bottom: 2rem;
    }

    .login-header h1 {
      font-size: 1.6rem;
    }
  }
</style>
