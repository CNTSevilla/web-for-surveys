---
/**
 * Layout.astro - Plantilla base HTML para todas las páginas del sitio.
 *
 * Proporciona la estructura HTML común incluyendo:
 * - Meta tags (charset, viewport, descripción)
 * - Fuentes de Google (Oswald + Source Sans 3)
 * - Favicon
 * - Script global para gestionar la apertura/cierre del modal de contacto
 * - Footer opcional con enlace a política de privacidad
 *
 * @prop {string} title - Título de la página (se muestra en la pestaña del navegador)
 * @prop {boolean} [showFooter=true] - Si se debe mostrar el footer con el enlace de privacidad
 */

import '../styles/global.css';
import '../styles/components.css';

interface Props {
  /** Título de la página */
  title: string;
  /** Controla la visibilidad del footer (por defecto: true) */
  showFooter?: boolean;
}

const { title, showFooter = true } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Lucha Sindical - Vivienda Digna para Todos"
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" sizes="64x64" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Source+Sans+3:wght@300;400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const modal = document.getElementById('contact-modal');
        const closeBtn = modal?.querySelector('.modal-close');

        document.querySelectorAll('[data-modal]').forEach(btn => {
          btn.addEventListener('click', function() {
            const modalId = this.dataset.modal;
            const targetModal = document.getElementById(modalId);
            if (targetModal) {
              targetModal.classList.remove('hidden');
            }
          });
        });

        if (closeBtn) {
          closeBtn.addEventListener('click', function() {
            modal.classList.add('hidden');
          });
        }

        if (modal) {
          modal.addEventListener('click', function(e) {
            if (e.target === modal) {
              modal.classList.add('hidden');
            }
          });
        }
      });
    </script>
    <slot />
    {showFooter && (
      <footer class="site-footer">
        <a href="/privacidad">Política de Privacidad</a>
      </footer>
    )}
  </body>
</html>
